      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${clickhouseDatasource}"
          },
          "editorType": "sql",
          "rawSql": "SELECT sum(d) AS value FROM (\n  SELECT concat(ResourceAttributes['k8s.pod.uid'], '/', ResourceAttributes['k8s.container.name']) AS c, max(Value) - min(Value) AS d\n  FROM ${database}.otel_metrics_gauge WHERE MetricName = 'k8s.container.restarts' AND $__timeFilter(TimeUnix) AND ResourceAttributes['k8s.namespace.name'] IN (${namespace:sqlstring})\n  GROUP BY c)",
