            "uid": "${clickhouseDatasource}"
          },
          "editorType": "sql",
          "rawSql": "SELECT $__timeInterval(TimeUnix) AS time, ResourceAttributes['k8s.node.name'] AS node, avg(Value) AS cpu_cores\nFROM ${database}.otel_metrics_gauge\nWHERE MetricName = 'k8s.node.cpu.usage' AND $__timeFilter(TimeUnix)\nGROUP BY time, node ORDER BY time",
          "queryType": "timeseries",
          "format": 0,
          "meta": {
