    {
      "id": null,
      "type": "timeseries",
      "title": "Top 10 pods by CPU (cores)",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${clickhouseDatasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
