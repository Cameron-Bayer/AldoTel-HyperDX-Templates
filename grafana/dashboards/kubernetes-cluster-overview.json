          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${clickhouseDatasource}"
          },
          "editorType": "sql",
          "rawSql": "SELECT ResourceAttributes['k8s.namespace.name'] AS \"Namespace\",\n       ResourceAttributes['k8s.pod.name'] AS \"Pod\",\n       ResourceAttributes['k8s.container.name'] AS \"Container\",\n       toUInt64(max(Value) - min(Value)) AS \"Restarts\"\nFROM ${database}.otel_metrics_gauge\nWHERE MetricName = 'k8s.container.restarts' AND $__timeFilter(TimeUnix) AND ResourceAttributes['k8s.namespace.name'] IN (${namespace:sqlstring})\nGROUP BY 1, 2, 3\nHAVING \"Restarts\" > 0\nORDER BY \"Restarts\" DESC\nLIMIT 20",
          "queryType": "table",
          "format": 1,
          "meta": {
            "builderOptions": {
              "database": "default",
              "mode": "trend"
            }
