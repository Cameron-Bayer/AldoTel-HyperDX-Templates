          "editorType": "sql",
          "rawSql": "SELECT time, host, 100 * avg(busy) AS \"cpu %\" FROM (\n  SELECT $__timeInterval(TimeUnix) AS time, ResourceAttributes['host.name'] AS host, Attributes['cpu'] AS cpu, TimeUnix,\n         sumIf(Value, Attributes['state'] != 'idle') AS busy\n  FROM ${database}.otel_metrics_gauge\n  WHERE MetricName = 'system.cpu.utilization' AND $__timeFilter(TimeUnix) AND ResourceAttributes['host.name'] IN (${host:sqlstring})\n  GROUP BY host, cpu, TimeUnix, time)\nGROUP BY time, host ORDER BY time",
          "queryType": "timeseries",
          "format": 0,
