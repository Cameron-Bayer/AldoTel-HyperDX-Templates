          "editorType": "sql",
          "rawSql": "SELECT time, host, sum(d) AS bytes FROM (\n  SELECT $__timeInterval(TimeUnix) AS time, ResourceAttributes['host.name'] AS host,\n         concat(Attributes['device'], '/', Attributes['direction']) AS s,\n         max(Value) - min(Value) AS d\n  FROM ${database}.otel_metrics_sum\n  WHERE MetricName = 'system.disk.io' AND $__timeFilter(TimeUnix) AND ResourceAttributes['host.name'] IN (${host:sqlstring})\n  GROUP BY time, host, s)\nGROUP BY time, host ORDER BY time",
