    {
      "id": null,
      "type": "table",
      "title": "Hosts summary (latest in range)",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${clickhouseDatasource}"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${clickhouseDatasource}"
          },
          "editorType": "sql",
          "rawSql": "SELECT c.host AS \"Host\",\n       round(c.cpu, 1) AS \"CPU %\",\n       round(m.mem, 1) AS \"Mem %\",\n       round(m.load, 2) AS \"Load 1m\",\n       round(m.swap, 1) AS \"Swap %\"\nFROM (\n  SELECT host, 100 * avg(busy) AS cpu FROM (\n    SELECT ResourceAttributes['host.name'] AS host, Attributes['cpu'] AS cpu, TimeUnix,\n         sumIf(Value, Attributes['state'] != 'idle') AS busy\n  FROM ${database}.otel_metrics_gauge\n  WHERE MetricName = 'system.cpu.utilization' AND $__timeFilter(TimeUnix) AND ResourceAttributes['host.name'] IN (${host:sqlstring})\n  GROUP BY host, cpu, TimeUnix)\n  GROUP BY host) c\nLEFT JOIN (\n  SELECT ResourceAttributes['host.name'] AS host,\n         100 * avgIf(Value, MetricName = 'system.memory.utilization' AND Attributes['state'] = 'used') AS mem,\n         avgIf(Value, MetricName = 'system.cpu.load_average.1m') AS load,\n         100 * avgIf(Value, MetricName = 'system.swap.utilization' AND Attributes['state'] = 'used') AS swap\n  FROM ${database}.otel_metrics_gauge\n  WHERE MetricName IN ('system.memory.utilization', 'system.cpu.load_average.1m', 'system.swap.utilization') AND $__timeFilter(TimeUnix) AND ResourceAttributes['host.name'] IN (${host:sqlstring})\n  GROUP BY host) m ON c.host = m.host\nORDER BY \"CPU %\" DESC",
          "queryType": "table",
          "format": 1,
          "meta": {
            "builderOptions": {
              "database": "default",
              "mode": "trend"
            }
          }
        }
