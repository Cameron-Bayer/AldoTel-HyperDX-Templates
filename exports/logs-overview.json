    {
      "id": "6a3c5ea81af7a534f76bf411",
      "x": 0,
      "y": 18,
      "w": 24,
      "h": 6,
      "config": {
        "displayType": "table",
        "configType": "sql",
        "sqlTemplate": "WITH normalized AS (\n  SELECT ServiceName,\n         replaceRegexpAll(replaceRegexpAll(Body, '[0-9]+', '<n>'), '[0-9a-fA-F-]{8,}', '<id>') AS pattern,\n         Timestamp\n  FROM default.otel_logs\n  WHERE lower(SeverityText) IN ('error','fatal') AND Timestamp > now() - INTERVAL 8 DAY AND $__filters\n)\nSELECT ServiceName, pattern,\n       countIf(Timestamp > now() - INTERVAL 1 DAY) AS last_24h,\n       countIf(Timestamp <= now() - INTERVAL 1 DAY) AS prior_7d\nFROM normalized\nGROUP BY ServiceName, pattern\nHAVING prior_7d = 0 AND last_24h > 0\nORDER BY last_24h DESC\nLIMIT 50",
        "connection": "Local ClickHouse",
        "source": "Logs",
        "name": "New log patterns in last 24h (vs prior 7d)"
      }
    },
